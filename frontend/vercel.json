{
  "buildCommand": "npm run build",
  "outputDirectory": ".output/public",
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "api/**.ts": {
      "runtime": "nodejs20.x"
    },
    "index.js": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.js"
    }
  ]
}
